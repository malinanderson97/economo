          <w:b/>
          <w:bCs/>
          <w:color w:val="0A2540"/>
          <w:sz w:val="23"/>
          <w:szCs w:val="23"/>
        </w:rPr>
        <w:t xml:space="preserve">Nothing installs — is that right?</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:rPr>
          <w:rFonts w:ascii="Hanken Grotesk" w:cs="Hanken Grotesk" w:eastAsia="Hanken Grotesk" w:hAnsi="Hanken Grotesk"/>
          <w:color w:val="425466"/>
          <w:sz w:val="22"/>
          <w:szCs w:val="22"/>
        </w:rPr>
        <w:t xml:space="preserve">Yes. It is one HTML file. Double-click it, or host it on your VLE. No IT involvement, works offline.</w:t>
      </w:r>
