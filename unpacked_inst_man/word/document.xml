      <w:pPr>
        <w:pStyle w:val="Heading2"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:rFonts w:ascii="Hanken Grotesk" w:cs="Hanken Grotesk" w:eastAsia="Hanken Grotesk" w:hAnsi="Hanken Grotesk"/>
          <w:b/>
          <w:bCs/>
          <w:color w:val="0A2540"/>
          <w:sz w:val="23"/>
          <w:szCs w:val="23"/>
        </w:rPr>
        <w:t xml:space="preserve">A permanent open-economy supply shock never settles.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:rPr>
          <w:rFonts w:ascii="Hanken Grotesk" w:cs="Hanken Grotesk" w:eastAsia="Hanken Grotesk" w:hAnsi="Hanken Grotesk"/>
          <w:color w:val="425466"/>
          <w:sz w:val="22"/>
          <w:szCs w:val="22"/>
        </w:rPr>
        <w:t xml:space="preserve">The open economy uses backward-looking exchange-rate expectations, so permanent supply shocks have no stationary equilibrium under UIP. Use transitory shocks; forward-looking FX dynamics are out of scope for this version.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:pPr>
